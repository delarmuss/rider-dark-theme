{
    "$schema": "vscode://schemas/color-theme",
    "name": "Rider Dark Theme",
    "type": "dark",
    "colors": {
        "editor.background": "#202020",
        "editor.foreground": "#D0D0D0",
        "editor.lineHighlightBackground": "#202424",
        "editor.selectionBackground": "#08335e",
        "editor.selectionHighlightBackground": "#08335e80",
        "editor.wordHighlightBackground": "#232E4680",
        "editor.wordHighlightStrongBackground": "#232E4680",
        "editor.findMatchBackground": "#144238",
        "editor.findMatchHighlightBackground": "#48401280",
        "editorLineNumber.foreground": "#808080",
        "editorLineNumber.activeForeground": "#F0F0F0",
        "editorCursor.foreground": "#F0F0F0",
        "editorCursor.background": "#000000",
        "editorWhitespace.foreground": "#686868",
        "editorIndentGuide.background1": "#404040",
        "editorIndentGuide.activeBackground1": "#404040",
        "editorBracketMatch.background": "#422240",
        "editorBracketMatch.border": "#422240",
        "editorError.foreground": "#FF5647",
        "editorWarning.foreground": "#F5D86A",
        "editorInfo.foreground": "#787878",
        "editorGutter.background": "#202020",
        "editorGutter.modifiedBackground": "#293A5F",
        "editorGutter.addedBackground": "#2C4722",
        "editorGutter.deletedBackground": "#BF3428",
        "editorOverviewRuler.border": "#202020",
        "diffEditor.insertedTextBackground": "#29421F40",
        "diffEditor.removedTextBackground": "#61272240",
        "activityBar.background": "#202020",
        "activityBar.foreground": "#d0d0d0",
        "activityBar.inactiveForeground": "#808080",
        "activityBarBadge.background": "#6C95EB",
        "activityBarBadge.foreground": "#FFFFFF",
        "sideBar.background": "#202020",
        "sideBar.foreground": "#d0d0d0",
        "sideBarTitle.foreground": "#d0d0d0",
        "sideBarSectionHeader.background": "#303030",
        "sideBarSectionHeader.foreground": "#d0d0d0",
        "statusBar.background": "#202020",
        "statusBar.foreground": "#d0d0d0",
        "statusBar.noFolderBackground": "#202020",
        "statusBar.debuggingBackground": "#6B4C1B",
        "statusBarItem.hoverBackground": "#303030",
        "titleBar.activeBackground": "#202020",
        "titleBar.activeForeground": "#d0d0d0",
        "titleBar.inactiveBackground": "#202020",
        "titleBar.inactiveForeground": "#808080",
        "titleBar.border": "#202020",
        "tab.activeBackground": "#202020",
        "tab.activeForeground": "#F0F0F0",
        "tab.inactiveBackground": "#202020",
        "tab.inactiveForeground": "#808080",
        "tab.border": "#202020",
        "tab.activeBorder": "#6C95EB",
        "editorGroupHeader.tabsBackground": "#202020",
        "editorGroupHeader.tabsBorder": "#202020",
        "panel.background": "#202020",
        "panel.border": "#202020",
        "panelTitle.activeForeground": "#d0d0d0",
        "panelTitle.inactiveForeground": "#808080",
        "panelTitle.activeBorder": "#6C95EB",
        "terminal.background": "#202020",
        "terminal.foreground": "#BDBDBD",
        "terminal.ansiBlack": "#202020",
        "terminal.ansiRed": "#FF5647",
        "terminal.ansiGreen": "#85C46C",
        "terminal.ansiYellow": "#D9B72B",
        "terminal.ansiBlue": "#6C95EB",
        "terminal.ansiMagenta": "#D688D4",
        "terminal.ansiCyan": "#39CC9B",
        "terminal.ansiWhite": "#BDBDBD",
        "terminal.ansiBrightBlack": "#666666",
        "terminal.ansiBrightRed": "#FF8870",
        "terminal.ansiBrightGreen": "#ADEB96",
        "terminal.ansiBrightYellow": "#F5D86A",
        "terminal.ansiBrightBlue": "#ADD3FF",
        "terminal.ansiBrightMagenta": "#FFBFFE",
        "terminal.ansiBrightCyan": "#7DF0C0",
        "terminal.ansiBrightWhite": "#F0F0F0",
        "input.background": "#303030",
        "input.foreground": "#d0d0d0",
        "input.border": "#202020",
        "input.placeholderForeground": "#808080",
        "dropdown.background": "#303030",
        "dropdown.foreground": "#d0d0d0",
        "dropdown.border": "#202020",
        "button.background": "#6C95EB",
        "button.foreground": "#ffffff",
        "list.activeSelectionBackground": "#232E46",
        "list.activeSelectionForeground": "#F0F0F0",
        "list.inactiveSelectionBackground": "#303030",
        "list.hoverBackground": "#232E46",
        "list.hoverForeground": "#ffffff",
        "list.focusBackground": "#232E46",
        "list.highlightForeground": "#6C95EB",
        "scrollbar.shadow": "#00000000",
        "scrollbarSlider.background": "#303030",
        "scrollbarSlider.hoverBackground": "#404040",
        "scrollbarSlider.activeBackground": "#232E46",
        "badge.background": "#6C95EB",
        "badge.foreground": "#ffffff",
        "progressBar.background": "#6C95EB",
        "focusBorder": "#202020",
        "foreground": "#d0d0d0",
        "selection.background": "#08335e",
        "widget.shadow": "#00000000"
    },
    "tokenColors": [
        {
            "name": "Text",
            "scope": [
                "source",
                "text"
            ],
            "settings": {
                "foreground": "#d0d0d0"
            }
        },
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#85C46C",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Doc Tag",
            "scope": [
                "storage.type.class.jsdoc",
                "punctuation.definition.block.tag.jsdoc"
            ],
            "settings": {
                "foreground": "#487D34"
            }
        },
        {
            "name": "Doc Tag Value",
            "scope": [
                "variable.other.jsdoc"
            ],
            "settings": {
                "foreground": "#C9A26D"
            }
        },
        {
            "name": "String",
            "scope": [
                "string",
                "string.quoted"
            ],
            "settings": {
                "foreground": "#C9A26D"
            }
        },
        {
            "name": "String Escape Valid",
            "scope": [
                "constant.character.escape"
            ],
            "settings": {
                "foreground": "#D688D4"
            }
        },
        {
            "name": "RegExp",
            "scope": [
                "string.regexp"
            ],
            "settings": {
                "foreground": "#FFD49E"
            }
        },
        {
            "name": "RegExp Quantifier",
            "scope": [
                "keyword.operator.quantifier.regexp"
            ],
            "settings": {
                "foreground": "#ADEB96"
            }
        },
        {
            "name": "RegExp Group",
            "scope": [
                "punctuation.definition.group.regexp"
            ],
            "settings": {
                "foreground": "#66C3CC"
            }
        },
        {
            "name": "RegExp Char Class",
            "scope": [
                "constant.other.character-class.regexp"
            ],
            "settings": {
                "foreground": "#C191FF"
            }
        },
        {
            "name": "Number",
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#ED94C0"
            }
        },
        {
            "name": "Boolean / Null / Language Constant",
            "scope": [
                "constant.language"
            ],
            "settings": {
                "foreground": "#6C95EB"
            }
        },
        {
            "name": "Keyword",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.operator.new",
                "storage.modifier",
                "storage.type"
            ],
            "settings": {
                "foreground": "#6C95EB"
            }
        },
        {
            "name": "Operator",
            "scope": [
                "keyword.operator"
            ],
            "settings": {
                "foreground": "#BDBDBD"
            }
        },
        {
            "name": "Punctuation",
            "scope": [
                "punctuation",
                "meta.brace",
                "meta.delimiter"
            ],
            "settings": {
                "foreground": "#BDBDBD"
            }
        },
        {
            "name": "Class Name",
            "scope": [
                "entity.name.type.class",
                "entity.name.type",
                "support.class"
            ],
            "settings": {
                "foreground": "#C191FF"
            }
        },
        {
            "name": "Interface Name",
            "scope": [
                "entity.name.type.interface"
            ],
            "settings": {
                "foreground": "#C191FF"
            }
        },
        {
            "name": "Enum",
            "scope": [
                "entity.name.type.enum"
            ],
            "settings": {
                "foreground": "#E1BFFF"
            }
        },
        {
            "name": "Struct",
            "scope": [
                "entity.name.type.struct"
            ],
            "settings": {
                "foreground": "#E1BFFF"
            }
        },
        {
            "name": "Namespace",
            "scope": [
                "entity.name.namespace",
                "entity.name.type.namespace"
            ],
            "settings": {
                "foreground": "#C191FF"
            }
        },
        {
            "name": "Type Parameter",
            "scope": [
                "entity.name.type.type-parameter"
            ],
            "settings": {
                "foreground": "#C191FF"
            }
        },
        {
            "name": "Function / Method",
            "scope": [
                "entity.name.function",
                "support.function"
            ],
            "settings": {
                "foreground": "#39CC9B"
            }
        },
        {
            "name": "Instance Field",
            "scope": [
                "variable.other.readwrite.instance",
                "variable.other.property"
            ],
            "settings": {
                "foreground": "#66C3CC"
            }
        },
        {
            "name": "Static Field / Constant",
            "scope": [
                "variable.other.constant",
                "support.constant"
            ],
            "settings": {
                "foreground": "#66C3CC"
            }
        },
        {
            "name": "Variable / Parameter",
            "scope": [
                "variable",
                "variable.other",
                "variable.parameter"
            ],
            "settings": {
                "foreground": "#BDBDBD"
            }
        },
        {
            "name": "Event",
            "scope": [
                "variable.other.event"
            ],
            "settings": {
                "foreground": "#ED94C0"
            }
        },
        {
            "name": "Decorator / Attribute",
            "scope": [
                "meta.decorator",
                "entity.name.type.annotation"
            ],
            "settings": {
                "foreground": "#C191FF"
            }
        },
        {
            "name": "HTML Tag",
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#C191FF"
            }
        },
        {
            "name": "HTML Attribute Name",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#85C46C"
            }
        },
        {
            "name": "HTML Attribute Value / String",
            "scope": [
                "string.quoted.double.html",
                "string.quoted.single.html"
            ],
            "settings": {
                "foreground": "#C9A26D"
            }
        },
        {
            "name": "HTML Entity",
            "scope": [
                "constant.character.entity"
            ],
            "settings": {
                "foreground": "#FFD49E"
            }
        },
        {
            "name": "CSS Property",
            "scope": [
                "support.type.property-name.css",
                "meta.property-name"
            ],
            "settings": {
                "foreground": "#6C95EB"
            }
        },
        {
            "name": "CSS Value",
            "scope": [
                "meta.property-value",
                "support.constant.property-value"
            ],
            "settings": {
                "foreground": "#F0F0F0"
            }
        },
        {
            "name": "CSS Selector",
            "scope": [
                "entity.name.tag.css",
                "entity.other.attribute-name.class.css",
                "entity.other.attribute-name.id.css",
                "entity.other.attribute-name.pseudo-class",
                "entity.other.attribute-name.pseudo-element"
            ],
            "settings": {
                "foreground": "#C191FF"
            }
        },
        {
            "name": "CSS Number",
            "scope": [
                "constant.numeric.css"
            ],
            "settings": {
                "foreground": "#ED94C0"
            }
        },
        {
            "name": "CSS Color",
            "scope": [
                "constant.other.color.rgb-value.css"
            ],
            "settings": {
                "foreground": "#ADEB96"
            }
        },
        {
            "name": "CSS String",
            "scope": [
                "string.quoted.double.css",
                "string.quoted.single.css"
            ],
            "settings": {
                "foreground": "#C9A26D"
            }
        },
        {
            "name": "CSS Function",
            "scope": [
                "support.function.misc.css"
            ],
            "settings": {
                "foreground": "#39CC9B"
            }
        },
        {
            "name": "CSS Important",
            "scope": [
                "keyword.other.important.css"
            ],
            "settings": {
                "foreground": "#E67281"
            }
        },
        {
            "name": "JSON Key",
            "scope": [
                "support.type.property-name.json"
            ],
            "settings": {
                "foreground": "#66C3CC"
            }
        },
        {
            "name": "JSON String",
            "scope": [
                "string.quoted.double.json"
            ],
            "settings": {
                "foreground": "#C9A26D"
            }
        },
        {
            "name": "JSON Number",
            "scope": [
                "constant.numeric.json"
            ],
            "settings": {
                "foreground": "#ED94C0"
            }
        },
        {
            "name": "JSON Keyword",
            "scope": [
                "constant.language.json"
            ],
            "settings": {
                "foreground": "#6C95EB"
            }
        },
        {
            "name": "XML/HTML Tag",
            "scope": [
                "entity.name.tag.xml",
                "entity.name.tag.html"
            ],
            "settings": {
                "foreground": "#C191FF"
            }
        },
        {
            "name": "XML Attribute",
            "scope": [
                "entity.other.attribute-name.xml"
            ],
            "settings": {
                "foreground": "#85C46C"
            }
        },
        {
            "name": "XML Attribute Value",
            "scope": [
                "string.quoted.double.xml"
            ],
            "settings": {
                "foreground": "#C9A26D"
            }
        },
        {
            "name": "YAML Key",
            "scope": [
                "entity.name.tag.yaml"
            ],
            "settings": {
                "foreground": "#C191FF"
            }
        },
        {
            "name": "YAML String",
            "scope": [
                "string.quoted.single.yaml",
                "string.quoted.double.yaml"
            ],
            "settings": {
                "foreground": "#C9A26D"
            }
        },
        {
            "name": "YAML Comment",
            "scope": [
                "comment.line.number-sign.yaml"
            ],
            "settings": {
                "foreground": "#85C46C",
                "fontStyle": "italic"
            }
        },
        {
            "name": "YAML Value",
            "scope": [
                "string.unquoted.yaml"
            ],
            "settings": {
                "foreground": "#BDBDBD"
            }
        },
        {
            "name": "Markdown Code",
            "scope": [
                "markup.inline.raw.markdown",
                "markup.fenced_code.block.markdown"
            ],
            "settings": {
                "foreground": "#85C46C"
            }
        },
        {
            "name": "Markdown Heading",
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#6C95EB"
            }
        },
        {
            "name": "Markdown Bold",
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markdown Italic",
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markdown Link",
            "scope": [
                "markup.underline.link"
            ],
            "settings": {
                "foreground": "#6C95EB"
            }
        },
        {
            "name": "Invalid",
            "scope": [
                "invalid"
            ],
            "settings": {
                "foreground": "#FF5647"
            }
        }
    ]
}
